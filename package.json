{
  "name": "autopartskrosa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "migrate-json": "node ./scripts/migrate-json-to-sqlite.js",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate && npm run migrate-json",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^4.2.1",
    "next": "^14.0.0",
    "nodemailer": "^7.0.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.4.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^5.18.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "24.9.2",
    "@types/react": "19.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^5.18.0",
    "tailwindcss": "^4.1.16",
    "typescript": "5.9.3"
  }
}
