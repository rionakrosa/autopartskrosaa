generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  price       String
  image       String
  description String
  // `Json` isn't supported by the SQLite connector in some environments.
  // Store the details array as a JSON-encoded string instead and parse/stringify in the API layer.
  details     String?
  bestSeller  Boolean @default(false)
}
